generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  STAFF
  USER
}

enum IngressoStatus {
  DISPONIVEL
  PENDENTE
  CANCELADO
}

enum InscricaoStatus {
  PENDENTE
  CONFIRMADA
  CANCELADA
}

model user {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  role          UserRole  @default(USER)
  phone         String?
  cpf           String?
  endereco      String?
  cidade        String?
  estado        String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions      session[]
  accounts      account[]
  ingressos     ingresso[]
  inscricoes    inscricao[]
}

model session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  user      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([providerId, accountId])
}

model verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt
}

model categoria {
  id        Int       @id @default(autoincrement())
  nome      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  produtos  produto[]
}

model produto {
  id          Int        @id @default(autoincrement())
  nome        String
  quantidade  Int        @default(0)
  preco       Float
  descricao   String?
  imagem      String?
  categoria   String?
  categoriaId Int?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  categoriaRef categoria? @relation(fields: [categoriaId], references: [id], onDelete: SetNull)
}

model evento {
  id         Int        @id @default(autoincrement())
  nomeEvento String
  local      String
  data       DateTime
  descricao  String?
  atracao    String?
  preco      Float?
  imagens    String[]   @default([])
  status     String     @default("Ativo")
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  ingressos  ingresso[]
}

model turma {
  id         Int        @id @default(autoincrement())
  nome       String
  local      String
  dataHora   DateTime
  descricao  String?
  preco      Float
  nivel      String
  imagens    String[]   @default([])
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  inscricoes inscricao[]
}

model ingresso {
  id        Int            @id @default(autoincrement())
  preco     Float
  qrcode    String         @unique
  userId    String
  eventoId  Int
  status    IngressoStatus @default(PENDENTE)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  usuario   user   @relation(fields: [userId], references: [id], onDelete: Cascade)
  evento    evento @relation(fields: [eventoId], references: [id], onDelete: Cascade)
}

model inscricao {
  id         Int              @id @default(autoincrement())
  dataHora   DateTime
  preco      Float
  local      String
  descricao  String?
  jaFoiAluno Boolean          @default(false)
  userId     String
  turmaId    Int
  status     InscricaoStatus  @default(PENDENTE)
  qrcode     String           @unique
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  usuario    user   @relation(fields: [userId], references: [id], onDelete: Cascade)
  turma      turma  @relation(fields: [turmaId], references: [id], onDelete: Cascade)

  @@unique([userId, turmaId])
}

model payment_record {
  id              Int      @id @default(autoincrement())
  reference       String   @unique
  kind            String
  userId          String   @map("user_id")
  targetIdsJson   String   @map("target_ids_json") @db.Text
  gatewayBillingId String? @unique @map("gateway_billing_id")
  checkoutUrl     String?  @map("checkout_url") @db.Text
  amount          Int      @default(0)
  status          String   @default("PENDING")
  rawResponseJson String?  @map("raw_response_json") @db.Text
  rawWebhookJson  String?  @map("raw_webhook_json") @db.Text
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([gatewayBillingId])
}
